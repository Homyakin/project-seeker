<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd"
>
    <changeSet context="legacy" author="Cursor" id="outpost-building-contribution">
        <createTable tableName="pgroup_outpost_building_contribution">
            <column name="pgroup_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="building_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="personage_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="materials" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
                tableName="pgroup_outpost_building_contribution"
                columnNames="pgroup_id, building_id, personage_id"
                constraintName="pgroup_outpost_building_contribution-pk"
        />
        <addForeignKeyConstraint
                baseTableName="pgroup_outpost_building_contribution"
                baseColumnNames="pgroup_id"
                constraintName="fk-pgroup_outpost_building_contribution-pgroup"
                referencedTableName="pgroup"
                referencedColumnNames="id"
        />
    </changeSet>
</databaseChangeLog>
