<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd"
>
    <changeSet context="legacy" author="Homyakin" id="drop-legacy-raid-history">
        <sql>
            TRUNCATE
                world_raid_launched_tg,
                world_raid_launched_pgroup,
                world_raid_research,
                world_raid_launched,
                world_raid_template,
                grouptg_to_launched_event,
                personage_to_event,
                personage_raid_result,
                launched_event_to_pgroup,
                pgroup_battle_result,
                launched_event;
        </sql>
    </changeSet>

    <changeSet context="legacy" author="Homyakin" id="recreate-raid-table">
        <dropForeignKeyConstraint baseTableName="raid" constraintName="fk_raid_raid_template"/>
        <dropForeignKeyConstraint baseTableName="raid" constraintName="fk_raid_event"/>
        <dropTable tableName="raid"/>
        <dropTable tableName="raid_template"/>

        <sql>DELETE FROM event WHERE type_id = 1;</sql>

        <createTable tableName="raid">
            <column name="event_id" type="INTEGER">
                <constraints primaryKey="true" primaryKeyName="raid_pkey"/>
            </column>
            <column name="locale" type="JSON" defaultValue="{}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseColumnNames="event_id"
                baseTableName="raid"
                constraintName="fk_raid_event"
                referencedColumnNames="id"
                referencedTableName="event"
        />
    </changeSet>
</databaseChangeLog>
